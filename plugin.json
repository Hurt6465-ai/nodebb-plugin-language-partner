{
  "id": "nodebb-plugin-language-partner",
  "name": "Language Partner",
  "description": "A HelloTalk-style language partner page for NodeBB",
  "url": "https://github.com/yourname/nodebb-plugin-language-partner",
  "library": "./library.js",
  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    },
    {
      "hook": "filter:admin.header.build",
      "method": "addAdminNavigation"
    }
  ],
  "scripts": [
    "public/lib/main.js",
    "public/lib/language-partners.js"
  ],
  "acpScripts": [
    "public/lib/acp-main.js",
    "public/lib/admin.js"
  ],
  "scss": [
    "scss/language-partners.scss"
  ],
  "templates": "templates",
  "languages": "languages"
}
